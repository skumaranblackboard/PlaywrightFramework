{
  "name": "advancedplaywrightframework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:critical": "npx playwright test --grep @smoke",
    "test:non-critical": "npx playwright test --grep @regression",
    "test:ci": "npx playwright test --grep @smoke --reporter=html,allure-playwright",
    "test:regression": "npx playwright test --grep @regression --reporter=html,allure-playwright",
    "test:oven": "npx playwright test src/tests/ --grep @oven --repeat-each=10 --retries=0 --pass-with-no-tests --reporter=html,allure-playwright",
    "moodle:up": "docker compose up -d",
    "moodle:wait": "bash scripts/wait-for-moodle.sh",
    "moodle:provision": "docker compose exec -T moodle php /scripts/provision-webservices.php",
    "moodle:setup": "npm run moodle:up && npm run moodle:wait && npm run moodle:provision",
    "moodle:down": "docker compose down -v",
    "report:allure": "allure generate allure-results --clean -o allure-report",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.60.0",
    "@types/chance": "^1.1.8",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.9.0",
    "chance": "^1.1.13",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}
