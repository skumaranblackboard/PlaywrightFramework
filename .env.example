# UI + API base URL. Points at the self-hosted Moodle (docker-compose.yml).
BASE_URL=http://localhost:8080
# Admin account created by the Moodle container (see docker-compose.yml).
MOODLE_USERNAME=admin
# Quote values containing '#', or dotenv treats it as a comment.
MOODLE_PASSWORD="Admin#12345"
# External web service created by scripts/provision-webservices.php.
MOODLE_SERVICE=automation
